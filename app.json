{
  "expo": {
    "name": "Stripes",
    "slug": "stripes",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "stripes",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#000000",
    "splash": {
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.stripes.app"
    },
    "android": {
      "package": "com.stripes.app",
      "adaptiveIcon": {
        "backgroundColor": "#000000"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-screen-orientation",
        {
          "initialOrientation": "PORTRAIT"
        }
      ],
      "expo-asset",
      "expo-font"
    ]
  }
}
